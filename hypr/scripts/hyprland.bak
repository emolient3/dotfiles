# This is an example Hyprland config file.
# Refer to the wiki for more information.
# https://wiki.hypr.land/Configuring/

# Please note not all available settings / options are set here.
# For a full list, see the wiki

# You can split this configuration into multiple files
# Create your files separately and then link them to this file like this:
# source = ~/.config/hypr/myColors.conf


################
### MONITORS ###
################

# See https://wiki.hypr.land/Configuring/Monitors/
#monitor=,preferred,auto,auto
monitor=DP-1,1920x1080@100,0x0,1
monitor=HDMI-A-1,1920x1080@120,1920x0,1

workspace = 1,monitor:HDMI-A-1, persistent:true
workspace = 2,monitor:DP-1, presistent:true



workspace = 9,monitor:HDMI-A-1, persistent:true
workspace = 8,monitor:DP-1, presistent:true


###################
### MY PROGRAMS ###
###################

# See https://wiki.hypr.land/Configuring/Keywords/

# Set programs that you use
$terminal = kitty
$fileManager = dolphin
$menu = wofi --show drun


#################
### AUTOSTART ###
#################

# Autostart necessary processes (like notifications daemons, status bars, etc.)
# Or execute your favorite apps at launch like this:

# exec-once = $terminal
# exec-once = nm-applet &
# exec-once = waybar & hyprpaper & firefox


#############################
### ENVIRONMENT VARIABLES ###
#############################

# See https://wiki.hypr.land/Configuring/Environment-variables/

env = XCURSOR_SIZE,24
env = HYPRCURSOR_SIZE,24


###################
### PERMISSIONS ###
###################

# See https://wiki.hypr.land/Configuring/Permissions/
# Please note permission changes here require a Hyprland restart and are not applied on-the-fly
# for security reasons

# ecosystem {
#   enforce_permissions = 1
# }

# permission = /usr/(bin|local/bin)/grim, screencopy, allow
# permission = /usr/(lib|libexec|lib64)/xdg-desktop-portal-hyprland, screencopy, allow
# permission = /usr/(bin|local/bin)/hyprpm, plugin, allow


#####################
### LOOK AND FEEL ###
#####################

# Refer to https://wiki.hypr.land/Configuring/Variables/

# https://wiki.hypr.land/Configuring/Variables/#general
general {
    gaps_in = 4
    gaps_out = 7

    border_size = 1 

    # https://wiki.hypr.land/Configuring/Variables/#variable-types for info about colors
    
    col.active_border = rgb(1EA8BA)

    col.inactive_border = rgb(4f4f4f)

    # Set to true enable resizing windows by clicking and dragging on borders and gaps
    resize_on_border = false

    # Please see https://wiki.hypr.land/Configuring/Tearing/ before you turn this on
    allow_tearing = false

    layout = dwindle
}

# https://wiki.hypr.land/Configuring/Variables/#decoration
decoration {
    rounding = 0 
    rounding_power = 2

    # Change transparency of focused and unfocused windows
    active_opacity = 1
    inactive_opacity = 1

    shadow {
        enabled = true
        range = 4
        render_power = 3
        color = rgba(1a1a1aee)
    }

    # https://wiki.hypr.land/Configuring/Variables/#blur
    blur {
        enabled = false
        size = 3
        passes = 1

        vibrancy = 0.1696
    }
}

# https://wiki.hypr.land/Configuring/Variables/#animations
animations {
    enabled = yes, please :)

    # Default curves, see https://wiki.hypr.land/Configuring/Animations/#curves
    #        NAME,           X0,   Y0,   X1,   Y1
    bezier = easeOutQuint,   0.23, 1,    0.32, 1
    bezier = easeInOutCubic, 0.65, 0.05, 0.36, 1
    bezier = linear,         0,    0,    1,    1
    bezier = almostLinear,   0.5,  0.5,  0.75, 1
    bezier = quick,          0.15, 0,    0.1,  1

    # Default animations, see https://wiki.hypr.land/Configuring/Animations/
    #           NAME,          ONOFF, SPEED, CURVE,        [STYLE]
    animation = global,        1,     10,    default
    animation = border,        1,     5.39,  easeOutQuint
    animation = windows,       1,     4.79,  easeOutQuint
    animation = windowsIn,     1,     4.1,   easeOutQuint, popin 87%
    animation = windowsOut,    1,     1.49,  linear,       popin 87%
    animation = fadeIn,        1,     1.73,  almostLinear
    animation = fadeOut,       1,     1.46,  almostLinear
    animation = fade,          1,     3.03,  quick
    animation = layers,        1,     3.81,  easeOutQuint
    animation = layersIn,      1,     4,     easeOutQuint, fade
    animation = layersOut,     1,     1.5,   linear,       fade
    animation = fadeLayersIn,  1,     1.79,  almostLinear
    animation = fadeLayersOut, 1,     1.39,  almostLinear
    animation = workspaces,    1,     1.94,  almostLinear, fade
    animation = workspacesIn,  1,     1.21,  almostLinear, fade
    animation = workspacesOut, 1,     1.94,  almostLinear, fade
    animation = zoomFactor,    1,     7,     quick
}

# Ref https://wiki.hypr.land/Configuring/Workspace-Rules/
# "Smart gaps" / "No gaps when only"
# uncomment all if you wish to use that.
# workspace = w[tv1], gapsout:0, gapsin:0
# workspace = f[1], gapsout:0, gapsin:0
# windowrule = bordersize 0, floating:0, onworkspace:w[tv1]
# windowrule = rounding 0, floating:0, onworkspace:w[tv1]
# windowrule = bordersize 0, floating:0, onworkspace:f[1]
# windowrule = rounding 0, floating:0, onworkspace:f[1]

# See https://wiki.hypr.land/Configuring/Dwindle-Layout/ for more
dwindle {
    pseudotile = true # Master switch for pseudotiling. Enabling is bound to mainMod + P in the keybinds section below
    preserve_split = true # You probably want this
}

# See https://wiki.hypr.land/Configuring/Master-Layout/ for more
master {
    new_status = master
}

# https://wiki.hypr.land/Configuring/Variables/#misc
misc {
    force_default_wallpaper = -1 # Set to 0 or 1 to disable the anime mascot wallpapers
    disable_hyprland_logo = false # If true disables the random hyprland logo / anime girl background. :(
}


#############
### INPUT ###
#############

# https://wiki.hypr.land/Configuring/Variables/#input
input {
    #kb_layout = latam
    kb_layout = us
    kb_variant =
    kb_model =
    kb_options =
    kb_rules =

    follow_mouse = 1

#SENSIBILIDAD DEL MOUSE
    sensitivity = 5.4  # -1.0 - 1.0, 0 means no modification.

    touchpad {
        natural_scroll = false
    }
}

#// gestos para touch pad lap
# https://wiki.hypr.land/Configuring/Variables/#gestures
#gestures {
#    workspace_swipe = false
#}

# Example per-device config
# See https://wiki.hypr.land/Configuring/Keywords/#per-device-input-configs for more
device {
    name = epic-mouse-v1
    sensitivity = -0.5
}


###################
### KEYBINDINGS ###
###################

# See https://wiki.hypr.land/Configuring/Keywords/
$mainMod = SUPER # Sets "Windows" key as main modifier

# Example binds, see https://wiki.hypr.land/Configuring/Binds/ for more
bind = $mainMod, Q, exec, kitty
bind = $mainMod, W, killactive,
#bind = $mainMod, M, exit,
bind = $mainMod, E, exec, firefox
bind = $mainMod, V, togglefloating,
bind = $mainMod, R, exec, $menu
bind = $mainMod, P, pseudo, # dwindle
bind = $mainMod, Z, togglesplit, # dwindle

# Redimensionar ventanas con SUPER + ALT + h/j/k/l
binde = SUPER ALT, h, resizeactive, -20 0   # reducir ancho
binde = SUPER ALT, l, resizeactive, 20 0    # aumentar ancho
binde = SUPER ALT, k, resizeactive, 0 -20   # reducir alto
binde = SUPER ALT, j, resizeactive, 0 20    # aumentar alto


# Move focus with mainMod + arrow keys
bind = $mainMod, H, movefocus, l
bind = $mainMod, L, movefocus, r
bind = $mainMod, K, movefocus, u
bind = $mainMod, J, movefocus, d

# Switch workspaces with mainMod + [0-9]
bind = $mainMod, 1, workspace, 2
bind = $mainMod, 2, workspace, 1
bind = $mainMod, 3, workspace, 3
bind = $mainMod, 4, workspace, 4
bind = $mainMod, 5, workspace, 5
bind = $mainMod, 6, workspace, 6
bind = $mainMod, 7, workspace, 7
bind = $mainMod, 8, workspace, 8
bind = $mainMod, 9, workspace, 9
bind = $mainMod, 0, workspace, 10
bind = $mainMod, n, workspace, 11
# Move active window to a workspace with mainMod + SHIFT + [0-9]
bind = $mainMod SHIFT, 1, movetoworkspace, 2
bind = $mainMod SHIFT, 2, movetoworkspace, 1
bind = $mainMod SHIFT, 3, movetoworkspace, 3
bind = $mainMod SHIFT, 4, movetoworkspace, 4
bind = $mainMod SHIFT, 5, movetoworkspace, 5
bind = $mainMod SHIFT, 6, movetoworkspace, 6
bind = $mainMod SHIFT, 7, movetoworkspace, 7
bind = $mainMod SHIFT, 8, movetoworkspace, 8
bind = $mainMod SHIFT, 9, movetoworkspace, 9
bind = $mainMod SHIFT, 0, movetoworkspace, 10
bind = $mainMod SHIFT, n, movetoworkspace, 11
# --- SWAP (swapwindow): intercambiar con la ventana en esa dirección ---
# Swap con la ventana a la derecha
bind = $mainMod SHIFT, L, swapwindow, r
# Swap con la ventana a la izquierda
bind = $mainMod SHIFT, H, swapwindow, l
# Swap arriba
bind = $mainMod SHIFT, K, swapwindow, u
# Swap abajo
bind = $mainMod SHIFT, J, swapwindow, d

#bind = $mainMod SHIFT, h, exec, /home/cali/.local/bin/move-float-to-monitor.sh h
#bind = $mainMod SHIFT, l, exec, /home/cali/.local/bin/move-float-to-monitor.sh l
#bind = $mainMod SHIFT, k, exec, /home/cali/.local/bin/move-float-to-monitor.sh k
#bind = $mainMod SHIFT, j, exec, /home/cali/.local/bin/move-float-to-monitor.sh j


# Toggle "fullscreen con bordes" (maximize) con $mainMod + F
bind = $mainMod, F, fullscreen, 1

# Minimizar todas las ventanas en todos los monitores
#bind = $mainMod, D, exec, hyprctl dispatch global short minimize

# --- Trasladar ventana en el layout con mainMod + Ctrl + hjkl ---

#bind = $mainMod CTRL, L, focusmonitor, +1

#bind = $mainMod SHIFT, L, movewindow, mon:+1
#bind = $mainMod SHIFT, L, centerwindow

#bind = $mainMod SHIFT, H, movewindow, mon:+1
#bind = $mainMod SHIFT, H, centerwindow

bind = $mainMod CTRL, H, movewindow, l
bind = $mainMod CTRL, L, movewindow, r
bind = $mainMod CTRL, K, movewindow, u
bind = $mainMod CTRL, J, movewindow, d

# Example special workspace (scratchpad)
bind = $mainMod, S, togglespecialworkspace, magic
bind = $mainMod SHIFT, S, movetoworkspace, special:magic
bind = $mainMod, i, movetoworkspace, +0
bind = $mainMod, x, togglespecialworkspace, basura
workspace = special:basura, gapsout:95,
# Scroll through existing workspaces with mainMod + scroll
bind = $mainMod, mouse_down, workspace, e+1
bind = $mainMod, mouse_up, workspace, e-1

# Move/resize windows with mainMod + LMB/RMB and dragging
bindm = $mainMod, mouse:272, movewindow
bindm = $mainMod, mouse:273, resizewindow

# Laptop multimedia keys for volume and LCD brightness
bindel = ,XF86AudioRaiseVolume, exec, wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
bindel = ,XF86AudioLowerVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindel = ,XF86AudioMute, exec, wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindel = ,XF86AudioMicMute, exec, wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindel = ,XF86MonBrightnessUp, exec, brightnessctl -e4 -n2 set 5%+
bindel = ,XF86MonBrightnessDown, exec, brightnessctl -e4 -n2 set 5%-

# Requires playerctl
bindl = , XF86AudioNext, exec, playerctl next
bindl = , XF86AudioPause, exec, playerctl play-pause
bindl = , XF86AudioPlay, exec, playerctl play-pause
bindl = , XF86AudioPrev, exec, playerctl previous

##############################
### WINDOWS AND WORKSPACES ###
##############################

# See https://wiki.hypr.land/Configuring/Window-Rules/ for more
# See https://wiki.hypr.land/Configuring/Workspace-Rules/ for workspace rules

# Example windowrule
# windowrule = float,class:^(kitty)$,title:^(kitty)$

# Ignore maximize requests from apps. You'll probably like this.
# windowrule = suppressevent maximize, class:.*

# Fix some dragging issues with XWayland
#windowrule = nofocus,class:^$,title:^$,xwayland:1,floating:1,fullscreen:0,pinned:0
#windowrulev2 = float,class:steamwebhelper fullscreen:1
#windowrulev2 = float,title:"Stremio" fullscreen:1

# Regla para color borde fullscreen
windowrule = border_color rgb(f47a80), match:fullscreen 1
# ejecutar hyprpaper wallpaper
exec-once = hyprpaper &
exec-once = systemctl --user start swayosd.service #servicio overlay sonido
exec-once = /home/cali/.config/hypr/scripts/float_small_windows.py #window float small title
exec-once = /home/cali/.local/bin/hyprbars-terminal
exec-once = discord --start-minimized
exec-once = steam  --start-minimized -silent &
#exec-once = hyprctl dispatch exec "[workspace special:magic silent] spotify"
#exec-once = hyprctl dispatch exec "[workspace special:magic silent] gtk-launch whatsapp.desktop"
#exec-once = hyprpanel #pkill gjs
#exec-once = firefox &
# ejemplo: ajustar ruta si es otra
plugin=/usr/lib/libhyprbars.so

plugin {
  hyprbars {
    enabled = true

    bar_height = 26
    bar_color = rgb(30343B)
    col.text = rgb(f8f8f2)
    bar_text_font = "JetBrainsMono Nerd Font"
    bar_text_size = 11
    bar_text_align = center
    bar_title_enabled = true

    bar_padding = 8
    bar_button_padding = 6
    bar_blur = false
    bar_part_of_window = true
    bar_precedence_over_border = true

    # Simular volumen: borde claro y sombra inferior
    bar_border_color_top = rgb(44475a)     # línea superior (más clara)
    bar_border_color_bottom = rgb(000000)  # línea inferior (simula sombra)
    bar_border_size = 1

    icon_on_hover = true

    hyprbars-button = rgb(ff5555), 12, 󰖭, hyprctl dispatch killactive, rgb(1e1f28)
    hyprbars-button = rgb(bd92f8), 12, , hyprctl dispatch fullscreen 1, rgb(1e1f28)
    hyprbars-button = rgb(8ae9fc), 12, , hyprctl dispatch togglefloating, rgb(1e1f28)

    on_double_click = hyprctl dispatch fullscreen 1
  }
}


# Selector de ventanas  #keybinds2
bind = $mainMod, a, exec, /home/cali/.local/bin/kitty-float #class:floatkitty
bind = $mainMod, space, exec, /home/cali/.local/bin/set_wallpaper.sh
bind = $mainMod, Tab, exec, /home/cali/.local/bin/sway-launcher.sh #class:launcher
bind = $mainMod, D, exec, /home/cali/.local/bin/hide_window.sh
bind = $mainMod, F12, exec, /home/cali/.local/bin/toogle-monitor-ON-OFF.sh
bind = $mainMod CTRL, u, centerwindow
bind = $mainMod, c, exec, /home/cali/.local/bin/workspaces89
bind = $mainMod CTRL,  F, exec, /home/cali/.local/bin/toggle_fullscreen_mode.sh
bind = ALT, Tab, cyclenext, floating # change focus to another window
bind = $mainMod SHIFT, x, exec, /home/cali/.local/bin/toggle_basura_workspace.sh
bind = $mainMod, i, exec, /home/cali/.local/bin/config.sh #class:config
bind = $mainMod, b, exec, /home/cali/.local/bin/toggle-hyprpanel.sh

# Screenshot a window
bind = $mainMod, home, exec, hyprshot -m window -z
bind = Ctrl, home, exec, hyprshot -m region -z # Screenshot a region
env = HYPRSHOT_DIR, $HOME/Imágenes/Capturas

#monitor screen
#bind = , PRINT, exec, hyprshot -m output



# lanzar desde un atajo: bind = SUPER, Return, exec, ~/.local/bin/kitty-float
windowrule {
    name = kitty-float
    match:class = floatkitty
    float = true
    size = 800 464
    center = true
  }
windowrule {
    name = config window I 
    match:class = config
    float = true
    size =  1028 946
    center = true
 }




#bind = $mainMod, u, togglefloating, centerwindow
# Siempre flotante
windowrulev2 = noblur,class:^(kitty)$,floating:0
windowrulev2 = noblur,class:steam,floating:0
windowrulev2 = noblur,class:discord,floating:0


windowrule {
    name = launcher_apps
    match:class = launcher
    stay_focused = true
    pin = true
    center = true
    size = 500 600
    float = true
  }

windowrule {
    name = noblur
    match:class = kitty
    no_blur = true
  }

# Quitar noblur para MonitorSelector SELECCIONAR MONITOR WALLPAPER, class python3/title MonitorSelector
windowrulev2 = stayfocused,title:^(MonitorSelector)$
windowrulev2 = float,class:(python3), title:^(MonitorSelector)*

# Ventana flotante grande centrada para previsualizar wallpapers
windowrulev2 = float,class:^(launcher_wallpaper)$

# Activar blur global
decoration:blur:enabled = true
decoration:blur:size = 5 
decoration:blur:passes = 2
decoration:blur:ignore_opacity = true
decoration:blur:new_optimizations = true
decoration:blur:xray = false
decoration:blur:noise = 0.03 #GRANULADO
decoration:blur:brightness = 0.8172
decoration:blur:vibrancy = 0.5
decoration:blur:vibrancy_darkness = 0.1
decoration:blur:special = false
decoration:blur:popups = true
decoration:blur:popups_ignorealpha = 0.2
decoration:blur:input_methods = true
decoration:blur:input_methods_ignorealpha = 1


# NO FUNCIONA :V
#windowrule = noblur, class:|Firefox|Spotify
windowrulev2 = opacity 0.9 0.9, class:^(zen)$
windowrulev2 = opacity 0.94 0.94, class:^(steam)$
#windowrulev2 = opacity 0.9 0.9, class:^(firefox)$
windowrulev2 = opacity 0.92 0.92, class:^(discord)$
windowrulev2 = opacity 0.78 0.78, class:^(Spotify)$
windowrulev2 = opacity 0.85 0.85, class:^(chrome-web.whatsapp.com__-Default)$
windowrulev2 = opacity 0.8 0.8, title:(ChatGPT — Mozilla Firefox)
windowrulev2 = opacity 0.8 0.8, title:(Inicio / X — Mozilla Firefox)

#########################################################


# Subir 1%
binde = SUPER, u, exec, pactl set-sink-volume @DEFAULT_SINK@ +5% && swayosd-client --output-volume raise

# Bajar 1%
binde = SUPER, y, exec, pactl set-sink-volume @DEFAULT_SINK@ -5% && swayosd-client --output-volume lower

# Mute toggle
# Toggle mute y mostrar overlay volumen volume
binde = SUPER, m, exec, pactl set-sink-mute @DEFAULT_SINK@ toggle



